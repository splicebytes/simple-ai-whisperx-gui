{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "core:default",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "shell:default",
    "shell:allow-open"
  ]
}