{
  "name": "simple-ai-whisperx-gui",
  "private": true,
  "version": "0.2.0",
  "description": "Simple AI transcription and summary GUI for WhisperX",
  "type": "module",
  "author": "Michał Skalczyński (skalunek) / SpliceBytes",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "npm run typecheck && npm run format:check && npm run clippy",
    "typecheck": "tsc --noEmit",
    "format:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
